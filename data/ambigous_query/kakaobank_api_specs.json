{
  "_meta": {
    "title": "카카오뱅크 AI 서비스 API 명세서",
    "description": "AI 검색 / AI 이체 / AI 금융계산기 / AI 모임총무 서비스에서 챗봇 에이전트가 호출하는 API 전체 목록. 멀티턴 대화 마지막 모호 쿼리 처리 데모용.",
    "version": "1.0.0",
    "base_url": "https://api.kakaobank.com",
    "auth": {
      "type": "Bearer Token",
      "header": "Authorization: Bearer {access_token}"
    },
    "common_headers": {
      "Content-Type": "application/json",
      "X-Request-ID": "UUID v4 (중복 방지)",
      "X-User-ID": "인증된 사용자 고유 식별자"
    },
    "services": ["AI_SEARCH", "AI_TRANSFER", "AI_CALCULATOR", "AI_GROUP_TREASURER"]
  },

  "apis": {

    "AI_SEARCH": {
      "description": "AI 검색 서비스. 카카오뱅크 상품·서비스 문의 및 일반 금융 지식 질의응답.",
      "endpoints": [

        {
          "api_id": "AS-01",
          "name": "질문 제출 및 답변 생성",
          "method": "POST",
          "endpoint": "/api/v1/ai-search/query",
          "description": "사용자의 자연어 질문을 수신하여 AI 답변, 관련 카카오뱅크 서비스 링크, 추가 추천 질문을 반환한다. 대화 이력을 함께 전달하면 멀티턴 문맥을 반영한 답변을 생성한다.",
          "request": {
            "query": {
              "type": "string",
              "required": true,
              "description": "사용자 자연어 질문",
              "example": "내 통장에 이번달 이자 얼마 붙었어?"
            },
            "session_id": {
              "type": "string",
              "format": "UUID v4",
              "required": true,
              "description": "동일 대화 세션 식별자. 멀티턴 문맥 유지에 사용."
            },
            "conversation_history": {
              "type": "array",
              "required": false,
              "description": "현재 세션 내 이전 턴의 질문-답변 이력 (멀티턴 문맥 제공용)",
              "items": {
                "role": "string — 'user' | 'assistant'",
                "content": "string — 발화 내용",
                "turn_index": "integer — 턴 순서 (0부터)"
              },
              "example": [
                { "role": "user", "content": "세이프박스 금리 얼마야?", "turn_index": 0 },
                { "role": "assistant", "content": "세이프박스 현재 금리는 연 2.5%입니다.", "turn_index": 1 }
              ]
            },
            "query_type_hint": {
              "type": "string",
              "required": false,
              "enum": ["KAKAOBANK_SERVICE", "FINANCIAL_KNOWLEDGE", "GENERAL", "AUTO"],
              "description": "질문 유형 힌트. AUTO 시 AI가 자동 분류.",
              "default": "AUTO"
            }
          },
          "response": {
            "answer": "string — AI 생성 답변 텍스트",
            "source_type": "string — 'KAKAOBANK_DOC' | 'AI_GENERATED' | 'MIXED'",
            "related_links": [
              {
                "label": "string — 링크 표시 이름",
                "url": "string — 카카오뱅크 앱 내 딥링크 또는 웹 URL",
                "service_type": "string — 연결 서비스 유형"
              }
            ],
            "suggested_questions": ["string — 추천 추가 질문 목록 (최대 3개)"],
            "session_id": "string — 세션 ID (에코)",
            "turn_index": "integer — 현재 턴 번호"
          }
        },

        {
          "api_id": "AS-02",
          "name": "답변 피드백 제출",
          "method": "POST",
          "endpoint": "/api/v1/ai-search/feedback",
          "description": "AI 답변에 대한 좋아요/싫어요 피드백을 수집한다.",
          "request": {
            "session_id": {
              "type": "string",
              "required": true,
              "description": "피드백 대상 세션 ID"
            },
            "turn_index": {
              "type": "integer",
              "required": true,
              "description": "피드백 대상 턴 번호"
            },
            "feedback_type": {
              "type": "string",
              "required": true,
              "enum": ["LIKE", "DISLIKE"],
              "description": "좋아요 / 싫어요"
            },
            "feedback_reason": {
              "type": "string",
              "required": false,
              "description": "싫어요 선택 시 사유 (선택 입력)"
            }
          },
          "response": {
            "feedback_id": "string — 피드백 처리 고유 ID",
            "status": "string — RECEIVED"
          }
        },

        {
          "api_id": "AS-03",
          "name": "카카오뱅크 서비스 연결 라우팅",
          "method": "POST",
          "endpoint": "/api/v1/ai-search/route",
          "description": "사용자 질문이 AI 이체 등 다른 AI 서비스 범위에 해당한다고 판단될 때, 해당 서비스로 전환하기 위한 라우팅 정보를 반환한다.",
          "request": {
            "query": {
              "type": "string",
              "required": true,
              "description": "사용자 자연어 질문"
            },
            "session_id": {
              "type": "string",
              "required": true
            }
          },
          "response": {
            "route_required": "boolean — 타 서비스 전환 필요 여부",
            "target_service": "string — 'AI_TRANSFER' | 'AI_CALCULATOR' | 'AI_GROUP_TREASURER' | null",
            "forwarded_context": "object — 전환 서비스에 전달할 문맥 정보"
          }
        }
      ]
    },

    "AI_TRANSFER": {
      "description": "AI 이체 서비스. 자연어 한 문장으로 이체 대상과 금액을 파악하여 이체를 실행한다.",
      "endpoints": [

        {
          "api_id": "AT-01",
          "name": "이체 대상 검색",
          "method": "GET",
          "endpoint": "/api/v1/transfer/recipients/search",
          "description": "사용자가 입력한 이름 또는 별명으로 최근 이체 이력 내 수신자 후보를 검색한다. 동명이인·동일 별명 복수 매핑 시 후보 목록을 반환한다.",
          "request": {
            "query": {
              "type": "string",
              "required": true,
              "description": "수신자 이름 또는 별명 (e.g. '엄마', '베프', '김이지')",
              "example": "베프"
            },
            "match_type": {
              "type": "string",
              "required": false,
              "enum": ["EXACT", "FUZZY", "ALIAS"],
              "default": "FUZZY",
              "description": "이름 매칭 방식"
            }
          },
          "response": {
            "candidates": [
              {
                "recipient_id": "string — 수신자 고유 ID",
                "display_name": "string — 표시 이름",
                "alias": "string | null — 사용자 지정 별명",
                "bank_name": "string — 수신 은행명",
                "masked_account": "string — 마스킹된 계좌번호 (e.g. 110-****-1234)",
                "last_transfer_date": "string — 최근 이체일 (ISO 8601)",
                "last_transfer_amount": "integer — 최근 이체 금액 (원)"
              }
            ],
            "total_count": "integer — 검색된 후보 수",
            "is_ambiguous": "boolean — 동명/동 별명 복수 후보 존재 여부"
          }
        },

        {
          "api_id": "AT-02",
          "name": "최근 이체 목록 조회",
          "method": "GET",
          "endpoint": "/api/v1/transfer/recipients/recent",
          "description": "사용자의 최근 이체 수신자 목록을 반환한다. AI 이체 화면 하단 '최근이체목록' 데이터 소스.",
          "request": {
            "limit": {
              "type": "integer",
              "required": false,
              "default": 20,
              "description": "반환할 최대 항목 수"
            },
            "include_alias": {
              "type": "boolean",
              "required": false,
              "default": true,
              "description": "별명 정보 포함 여부"
            }
          },
          "response": {
            "recipients": [
              {
                "recipient_id": "string",
                "display_name": "string",
                "alias": "string | null",
                "bank_name": "string",
                "masked_account": "string",
                "last_transfer_date": "string",
                "last_transfer_amount": "integer"
              }
            ]
          }
        },

        {
          "api_id": "AT-03",
          "name": "출금 계좌 잔액 조회",
          "method": "GET",
          "endpoint": "/api/v1/transfer/accounts/balance",
          "description": "이체 시 출금 가능한 사용자 계좌 목록과 각 계좌의 잔액을 반환한다.",
          "request": {
            "account_type_filter": {
              "type": "string",
              "required": false,
              "enum": ["ALL", "CHECKING", "SAVINGS"],
              "default": "CHECKING",
              "description": "조회할 계좌 유형 필터"
            }
          },
          "response": {
            "accounts": [
              {
                "account_id": "string — 계좌 내부 ID",
                "account_number": "string — 마스킹 계좌번호",
                "account_type": "string — 계좌 유형",
                "balance": "integer — 현재 잔액 (원)",
                "available_balance": "integer — 출금 가능 잔액 (원)",
                "is_primary": "boolean — 주 출금 계좌 여부"
              }
            ]
          }
        },

        {
          "api_id": "AT-04",
          "name": "이체 정보 검증",
          "method": "POST",
          "endpoint": "/api/v1/transfer/validate",
          "description": "실제 이체 실행 전, 수신자·금액·출금 가능 여부를 검증하고 최종 확인용 이체 정보를 반환한다. 이체 한도(1일 200만원) 초과 여부도 이 단계에서 확인.",
          "request": {
            "recipient_id": {
              "type": "string",
              "required": true,
              "description": "이체 대상 수신자 고유 ID (AT-01 검색 결과)"
            },
            "amount": {
              "type": "integer",
              "required": true,
              "description": "이체 금액 (원 단위)",
              "example": 50000
            },
            "source_account_id": {
              "type": "string",
              "required": false,
              "description": "출금 계좌 ID. 미지정 시 주 출금 계좌 사용."
            },
            "memo": {
              "type": "string",
              "required": false,
              "description": "이체 메모 (입금자명 적요)",
              "max_length": 20
            }
          },
          "response": {
            "is_valid": "boolean — 이체 가능 여부",
            "validation_errors": [
              {
                "error_code": "string — INSUFFICIENT_BALANCE | DAILY_LIMIT_EXCEEDED | RECIPIENT_NOT_FOUND | ACCOUNT_SUSPENDED",
                "message": "string — 오류 메시지"
              }
            ],
            "transfer_summary": {
              "recipient_name": "string",
              "bank_name": "string",
              "masked_account": "string",
              "amount": "integer",
              "fee": "integer — 이체 수수료 (원)",
              "total_deduction": "integer — 총 차감액",
              "remaining_daily_limit": "integer — 당일 잔여 이체 한도 (원)"
            }
          }
        },

        {
          "api_id": "AT-05",
          "name": "이체 실행",
          "method": "POST",
          "endpoint": "/api/v1/transfer/execute",
          "description": "검증(AT-04)이 완료된 이체 정보를 바탕으로 실제 이체를 실행한다. 인증 토큰 필수.",
          "request": {
            "recipient_id": {
              "type": "string",
              "required": true
            },
            "amount": {
              "type": "integer",
              "required": true
            },
            "source_account_id": {
              "type": "string",
              "required": false
            },
            "memo": {
              "type": "string",
              "required": false
            },
            "auth_token": {
              "type": "string",
              "required": true,
              "description": "사용자 인증 토큰 (생체인증·PIN 완료 후 발급)"
            },
            "idempotency_key": {
              "type": "string",
              "format": "UUID v4",
              "required": true,
              "description": "중복 이체 방지 키"
            }
          },
          "response": {
            "transaction_id": "string — 이체 거래 고유 ID",
            "status": "string — COMPLETED | FAILED",
            "completed_at": "string — 처리 완료 시각 (ISO 8601)",
            "receipt": {
              "sender_account": "string",
              "recipient_name": "string",
              "recipient_account": "string",
              "amount": "integer",
              "fee": "integer",
              "balance_after": "integer — 이체 후 잔액"
            }
          }
        },

        {
          "api_id": "AT-06",
          "name": "별명 등록·수정",
          "method": "PUT",
          "endpoint": "/api/v1/transfer/recipients/{recipient_id}/alias",
          "description": "수신자 계좌에 별명을 등록하거나 수정한다.",
          "request": {
            "recipient_id": {
              "type": "string",
              "required": true,
              "in": "path"
            },
            "alias": {
              "type": "string",
              "required": true,
              "description": "등록할 별명 (e.g. '베프', '엄마')",
              "max_length": 10
            }
          },
          "response": {
            "recipient_id": "string",
            "alias": "string",
            "updated_at": "string"
          }
        }
      ]
    },

    "AI_CALCULATOR": {
      "description": "AI 금융계산기 서비스. 예·적금 이자, 대출 상환, 환율 조회·변환, 목표 저축 금액 계산.",
      "endpoints": [

        {
          "api_id": "AC-01",
          "name": "예금 이자 계산",
          "method": "POST",
          "endpoint": "/api/v1/calculator/deposit",
          "description": "정기예금 상품에 대해 원금·금리·기간 조건으로 만기 수령액과 이자를 계산한다.",
          "request": {
            "product_id": {
              "type": "string",
              "required": false,
              "description": "카카오뱅크 예금 상품 ID. 미지정 시 custom_rate 필수.",
              "example": "PRD-DEP-001"
            },
            "principal": {
              "type": "integer",
              "required": true,
              "description": "예치 원금 (원 단위)",
              "example": 12000000
            },
            "duration_months": {
              "type": "integer",
              "required": true,
              "description": "예치 기간 (개월 수)",
              "example": 12
            },
            "custom_rate": {
              "type": "number",
              "required": false,
              "description": "사용자 지정 연 금리 (%). product_id 미지정 시 필수.",
              "example": 3.8
            },
            "interest_type": {
              "type": "string",
              "required": false,
              "enum": ["SIMPLE", "COMPOUND"],
              "default": "SIMPLE",
              "description": "이자 계산 방식 (단리/복리)"
            },
            "tax_type": {
              "type": "string",
              "required": false,
              "enum": ["GENERAL", "TAX_FREE", "TAX_REDUCED"],
              "default": "GENERAL",
              "description": "과세 유형 (일반과세 15.4% / 비과세 / 세금우대)"
            }
          },
          "response": {
            "product_name": "string | null",
            "principal": "integer",
            "applied_rate": "number — 적용 연 금리 (%)",
            "duration_months": "integer",
            "gross_interest": "integer — 세전 이자 (원)",
            "tax_amount": "integer — 세금 (원)",
            "net_interest": "integer — 세후 이자 (원)",
            "maturity_amount": "integer — 만기 수령액 (원)",
            "calculation_basis": "string — 계산 기준 설명"
          }
        },

        {
          "api_id": "AC-02",
          "name": "자유적금 이자 계산",
          "method": "POST",
          "endpoint": "/api/v1/calculator/savings/flexible",
          "description": "자유적금(자유납입식 적금) 상품에 대해 월 납입액·기간·금리 조건으로 만기 수령액을 계산한다.",
          "request": {
            "product_id": {
              "type": "string",
              "required": false,
              "description": "카카오뱅크 자유적금 상품 ID"
            },
            "monthly_amount": {
              "type": "integer",
              "required": true,
              "description": "월 납입액 (원 단위)",
              "example": 300000
            },
            "duration_months": {
              "type": "integer",
              "required": true,
              "description": "납입 기간 (개월 수)",
              "example": 36
            },
            "custom_rate": {
              "type": "number",
              "required": false,
              "description": "사용자 지정 연 금리 (%)"
            },
            "tax_type": {
              "type": "string",
              "required": false,
              "enum": ["GENERAL", "TAX_FREE", "TAX_REDUCED"],
              "default": "GENERAL"
            }
          },
          "response": {
            "product_name": "string | null",
            "total_principal": "integer — 총 납입 원금",
            "applied_rate": "number",
            "gross_interest": "integer",
            "tax_amount": "integer",
            "net_interest": "integer",
            "maturity_amount": "integer",
            "monthly_limit": "integer | null — 해당 상품 월 최대 납입 한도",
            "limit_exceeded": "boolean — 입력 금액이 한도 초과 여부"
          }
        },

        {
          "api_id": "AC-03",
          "name": "정기적금 이자 계산",
          "method": "POST",
          "endpoint": "/api/v1/calculator/savings/fixed",
          "description": "정기납입 적금 상품에 대해 월 납입액·기간·금리 조건으로 만기 수령액을 계산한다.",
          "request": {
            "product_id": { "type": "string", "required": false },
            "monthly_amount": { "type": "integer", "required": true, "example": 1000000 },
            "duration_months": { "type": "integer", "required": true, "example": 12 },
            "custom_rate": { "type": "number", "required": false },
            "tax_type": { "type": "string", "required": false, "default": "GENERAL" }
          },
          "response": {
            "product_name": "string | null",
            "total_principal": "integer",
            "applied_rate": "number",
            "gross_interest": "integer",
            "tax_amount": "integer",
            "net_interest": "integer",
            "maturity_amount": "integer"
          }
        },

        {
          "api_id": "AC-04",
          "name": "세이프박스 이자 계산",
          "method": "POST",
          "endpoint": "/api/v1/calculator/safebox",
          "description": "카카오뱅크 세이프박스 상품에 대해 예치 금액과 기간으로 이자를 계산한다. 예치일 단위 계산 지원.",
          "request": {
            "amount": {
              "type": "integer",
              "required": false,
              "description": "예치 금액 (원 단위). target_interest 지정 시 생략 가능.",
              "example": 100000000
            },
            "duration_days": {
              "type": "integer",
              "required": false,
